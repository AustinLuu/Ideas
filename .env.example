# --- Required ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Optional ---
# Claude model to use for idea generation. claude-haiku-4-5-20251001 is a
# cheaper option if you don't need Sonnet-level idea quality.
CLAUDE_MODEL=claude-sonnet-5

# How many ideas to generate per post
NUM_IDEAS=3

# How many days back to look for "recently created" GitHub repos
TRENDING_WINDOW_DAYS=2

# Restrict GitHub trending search to one language, e.g. python, typescript.
# Leave blank for no filter.
GITHUB_LANGUAGE=

# Optional: raises GitHub API rate limit from 60/hr to 5000/hr.
# Create at https://github.com/settings/tokens (no special scopes needed
# for public repo search).
GITHUB_TOKEN=

# --- Only used when RUN_MODE=loop (persistent host like Railway/Fly) ---
RUN_MODE=once
SCHEDULE_FREQUENCY=daily
SCHEDULE_TIME=09:00
SCHEDULE_DAY=monday
